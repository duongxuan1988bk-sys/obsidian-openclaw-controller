{
  "name": "obsidian-to-openclaw",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Obsidian plugin for connecting to OpenClaw, referencing notes, and running basic note workflows.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/duongxuan1988bk-sys/obsidian-openclaw-controller.git"
  },
  "homepage": "https://github.com/duongxuan1988bk-sys/obsidian-openclaw-controller",
  "bugs": {
    "url": "https://github.com/duongxuan1988bk-sys/obsidian-openclaw-controller/issues"
  },
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "test": "node ./scripts/test.mjs",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && npm run test && npm run build:css && npm run build:ts",
    "build:ts": "node ./esbuild.config.mjs --prod",
    "build:css": "./node_modules/.bin/tailwindcss -i ./src/styles.css -o ./styles.css --minify"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.542.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.11",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "esbuild": "^0.25.9",
    "obsidian": "^1.8.7",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.2"
  }
}
